# Copy to .env and replace every value before production use.

LATTICE_ADMIN_PASSWORD=replace-with-a-long-random-password
LATTICE_PUBLIC_URL=https://lattice.example.com

# Enable only when the only public path to the container is a trusted reverse
# proxy that sets CF-Connecting-IP or X-Forwarded-For correctly.
LATTICE_TRUST_PROXY=1

# Set when TLS is terminated by a trusted reverse proxy and users access the
# dashboard over HTTPS.
LATTICE_SECURE_COOKIES=1

# Optional plugin trust policy JSON mounted from ./data or baked into your host.
# LATTICE_PLUGIN_TRUST=/var/lib/lattice/plugin-trust.json
